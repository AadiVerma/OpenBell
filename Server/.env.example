# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/openbell

# ── Anthropic ────────────────────────────────────────────────────────────────────
# Option A: Direct API key (uses Anthropic SDK + tool_use — most token-efficient)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option B: Leave ANTHROPIC_API_KEY blank — falls back to `claude` CLI subprocess
# (works with Claude Code subscription, no separate API key needed)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Market data (optional — only needed for non-Indian stocks) ───────────────────
FINNHUB_API_KEY=

# ── Twilio / WhatsApp ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
WHATSAPP_ENABLED=false

# ── App behaviour ─────────────────────────────────────────────────────────────────
PORTFOLIO_BUDGET=10000.0
